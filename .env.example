# ─── Database ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=job_market
DB_USER=postgres
DB_PASSWORD=your_password_here

# ─── Scraper ────────────────────────────────────────────────
HEADLESS=true
SCRAPER_DELAY_MIN=2
SCRAPER_DELAY_MAX=5
MAX_RETRIES=3

# ─── LinkedIn (optional: session cookies for auth) ──────────
LINKEDIN_EMAIL=your_email@example.com
LINKEDIN_PASSWORD=your_password_here

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/pipeline.log
